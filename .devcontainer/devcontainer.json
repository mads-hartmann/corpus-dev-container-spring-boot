{
	"name": "Spring Boot (Java 21)",
	"image": "mcr.microsoft.com/devcontainers/java:21",
	"forwardPorts": [8080],
	"portsAttributes": {
		"8080": {
			"label": "Spring Boot",
			"onAutoForward": "notify"
		}
	}
}
